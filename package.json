{
  "name": "web-drum-sequencer",
  "version": "0.2.4",
  "description": "A drum machine and sequencer built with the Web Audio API and React.",
  "main": "dist/index.html",
  "scripts": {
    "start": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "gh-pages": "git subtree push --prefix dist origin gh-pages"
  },
  "author": "Stu Freen, Tim Howard",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tdhoward/web-drum-sequencer-2.git"
  },
  "keywords": [
    "Web Audio",
    "Web Audio API",
    "Drum Machine",
    "Playback",
    "Effect",
    "Instrument",
    "React",
    "Redux",
    "Interactive Music"
  ],
  "devDependencies": {
    "@babel/core": "^7.22.9",
    "@babel/eslint-parser": "^7.22.9",
    "@babel/preset-env": "^7.22.9",
    "@babel/preset-react": "^7.22.5",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^9.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.36",
    "@types/styled-system": "^5.1.25",
    "@vitejs/plugin-react": "^4.7.0",
    "babel-plugin-macros": "^3.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.33.1",
    "globals": "^16.0.0",
    "jest": "^30.4.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.4.2",
    "vite-plugin-svgr": "^5.2.0"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@shopify/draggable": "^1.0.0-beta.8",
    "animol": "1.0.9",
    "core-js": "^3.49.0",
    "prop-types": "^15.6.2",
    "ramda": "^0.32.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-select": "^5.10.2",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "reselect": "^5.2.0",
    "styled-components": "^5.3.11",
    "styled-system": "^3.0.2"
  },
  "jest": {
    "moduleNameMapper": {
      "^recompose$": "<rootDir>/src/recompose.js",
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js",
      "\\.(css|less)$": "<rootDir>/__mocks__/styleMock.js"
    },
    "testEnvironmentOptions": {
      "url": "http://localhost"
    }
  }
}
